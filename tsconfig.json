{
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "checkJs": true,
    "declaration": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node", "vitest"]
  },
  "include": [
    "src/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/tests/**/*.mjs",
    "scripts/**/*.mjs",
    "tests/**/*.mjs"
  ],
  "exclude": ["coverage", "dist", "node_modules"]
}
