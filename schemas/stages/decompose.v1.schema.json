{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "decompose.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "assumptions",
    "references",
    "next_state",
    "story_units"
  ],
  "properties": {
    "stage": { "type": "string", "const": "decompose" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "options"],
        "properties": {
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string" }
          }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": { "type": "string", "enum": ["ready-for-materialization", "blocked"] },
    "story_units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "background",
          "requirements",
          "acceptance_criteria",
          "backpressure_commands",
          "blocked_by",
          "parallel_group",
          "review_guidelines"
        ],
        "properties": {
          "title": { "type": "string" },
          "background": { "type": "string" },
          "requirements": { "type": "array", "items": { "type": "string" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "backpressure_commands": { "type": "array", "items": { "type": "string" } },
          "blocked_by": { "type": "array", "items": { "type": "string" } },
          "parallel_group": { "type": "string" },
          "review_guidelines": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "completed" }
        }
      },
      "then": {
        "properties": {
          "next_state": { "const": "ready-for-materialization" },
          "story_units": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "blocked" }
        }
      },
      "then": {
        "properties": {
          "next_state": { "const": "blocked" }
        }
      }
    }
  ]
}
