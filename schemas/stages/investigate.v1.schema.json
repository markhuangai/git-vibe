{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "investigate.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "blocking_questions",
    "assumptions",
    "references",
    "next_state"
  ],
  "properties": {
    "stage": { "type": "string", "const": "investigate" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "blocking_questions": { "type": "array", "items": { "type": "string" } },
    "questions": { "type": "array", "items": { "type": "string" } },
    "implementation_plan": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": {
      "type": "string",
      "enum": ["needs-info", "ready-for-validation", "ready-for-implementation", "blocked"]
    },
    "proposed_labels": { "type": "array", "items": { "type": "string" } },
    "branch": { "type": "string" },
    "pr_title": { "type": "string" },
    "pr_body": { "type": "string" },
    "issue_title": { "type": "string" },
    "issue_body": { "type": "string" },
    "tests": { "type": "array", "items": { "type": "string" } },
    "skipped_feedback": { "type": "array", "items": { "type": "string" } }
  }
}
