{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "materialize.v1",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "options"],
      "properties": {
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string" }
        }
      }
    },
    "questionItem": {
      "oneOf": [{ "type": "string" }, { "$ref": "#/definitions/question" }]
    }
  },
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "assumptions",
    "references",
    "next_state",
    "issue_title",
    "issue_body"
  ],
  "properties": {
    "stage": { "type": "string", "const": "materialize" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "questions": { "type": "array", "items": { "$ref": "#/definitions/questionItem" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": { "type": "string", "enum": ["implementation-issue-ready", "blocked"] },
    "issue_title": { "type": "string" },
    "issue_body": { "type": "string" }
  }
}
