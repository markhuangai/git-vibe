{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "address-pr-feedback.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "assumptions",
    "references",
    "next_state",
    "tests",
    "skipped_feedback"
  ],
  "properties": {
    "stage": { "type": "string", "const": "address-pr-feedback" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": { "type": "string", "enum": ["feedback-addressed", "blocked"] },
    "tests": { "type": "array", "items": { "type": "string" } },
    "skipped_feedback": { "type": "array", "items": { "type": "string" } }
  }
}
