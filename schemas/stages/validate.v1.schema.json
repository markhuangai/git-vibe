{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "validate.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "assumptions",
    "references",
    "next_state"
  ],
  "properties": {
    "stage": { "type": "string", "const": "validate" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "working_capabilities": { "type": "array", "items": { "type": "string" } },
    "missing_capabilities": { "type": "array", "items": { "type": "string" } },
    "partial_capabilities": { "type": "array", "items": { "type": "string" } },
    "questions": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": {
      "type": "string",
      "enum": ["ready-for-implementation", "needs-info", "blocked"]
    },
    "proposed_labels": { "type": "array", "items": { "type": "string" } }
  }
}
