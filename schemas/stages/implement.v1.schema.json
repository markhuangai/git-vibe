{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "implement.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "summary",
    "comment_body",
    "findings",
    "assumptions",
    "references",
    "next_state",
    "tests"
  ],
  "properties": {
    "stage": { "type": "string", "const": "implement" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "summary": { "type": "string" },
    "comment_body": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "options"],
        "properties": {
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string" }
          }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "next_state": { "type": "string", "enum": ["changes-ready-for-commit", "blocked"] },
    "branch": { "type": "string" },
    "tests": { "type": "array", "items": { "type": "string" } }
  }
}
